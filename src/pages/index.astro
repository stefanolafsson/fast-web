---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Forsíða">
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content">
        <p class="hero-badge">Aðildarfélag BHM</p>
        <h1 class="hero-title">FAST</h1>
        <p class="hero-subtitle">Félag akademískra starfsmanna við Háskólann í Reykjavík</p>
        <p class="hero-desc">
          Við stöndum vörð um réttindi og kjör akademískra starfsmanna og vinnum
          að bættum starfsskilyrðum í háskólasamfélaginu.
        </p>
        <div class="hero-actions">
          <a href={`${base}um-felagid/`} class="btn btn-primary">Um félagið</a>
          <a href={`${base}hafa-samband/`} class="btn btn-secondary">Hafa samband</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">Hvað gerir FAST?</h2>
      <p class="section-subtitle">
        Félagið gætir hagsmuna akademískra starfsmanna og vinnur að bættum kjörum og starfsumhverfi.
      </p>
      <div class="grid-3">
        <div class="card">
          <div class="card-icon">&#9878;</div>
          <h3 class="card-title">Kjarasamningar</h3>
          <p class="card-text">
            FAST vinnur með BHM að gerð kjarasamninga sem tryggja sanngjarnt
            endurgjald og góð starfskjör fyrir akademískt starfsfólk.
          </p>
        </div>
        <div class="card">
          <div class="card-icon">&#9733;</div>
          <h3 class="card-title">Hagsmunagæsla</h3>
          <p class="card-text">
            Félagið stendur vörð um réttindi félagsmanna gagnvart vinnuveitanda
            og tryggir að farið sé eftir kjarasamningum og lögum.
          </p>
        </div>
        <div class="card">
          <div class="card-icon">&#9825;</div>
          <h3 class="card-title">Starfsumhverfi</h3>
          <p class="card-text">
            Við leggjum áherslu á gott starfsumhverfi, jafnrétti og
            vellíðan á vinnustað fyrir alla félagsmenn.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">Fréttir</h2>
      <p class="section-subtitle">Nýjustu fréttir og tilkynningar frá FAST.</p>
      <div class="grid-2">
        <article class="news-card">
          <span class="tag">Tilkynning</span>
          <h3><a href={`${base}frettir/adalfundur-fast-2026/`}>Aðalfundur FAST 2026</a></h3>
          <p>Aðalfundur félagsins verður haldinn í mars 2026. Nánari upplýsingar og dagskrá verða birtar hér á vefnum.</p>
          <time>Febrúar 2026</time>
        </article>
        <article class="news-card">
          <span class="tag">Kjaramál</span>
          <h3><a href={`${base}frettir/kjarasamningar-stadan/`}>Kjarasamningar — nýjustu upplýsingar</a></h3>
          <p>Upplýsingar um gildandi kjarasamninga og réttindi félagsmanna má finna á kjaramálasíðu félagsins.</p>
          <time>Febrúar 2026</time>
        </article>
      </div>
      <div class="news-more">
        <a href={`${base}frettir/`} class="btn btn-outline">Allar fréttir</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container cta-box">
      <h2>Aðildarfélag BHM</h2>
      <p>
        FAST er aðildarfélag <a href="https://www.bhm.is" target="_blank" rel="noopener">Bandalags háskólamanna (BHM)</a>
        sem er heildarsamtök 27 stéttarfélaga háskólamenntaðs fólks á Íslandi.
      </p>
      <a href="https://www.bhm.is" target="_blank" rel="noopener" class="btn btn-outline">Skoða BHM</a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-primary) 40%, var(--color-primary-light) 100%);
    padding: calc(var(--header-height) + var(--space-16)) 0 var(--space-20);
    position: relative;
    overflow: hidden;
    min-height: 520px;
    display: flex;
    align-items: center;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.03);
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: -30%;
    left: -10%;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.02);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 640px;
  }

  .hero-badge {
    display: inline-block;
    padding: var(--space-1) var(--space-4);
    background: rgba(255, 255, 255, 0.15);
    color: rgba(255, 255, 255, 0.9);
    border-radius: 100px;
    font-size: var(--size-sm);
    font-weight: 500;
    margin-bottom: var(--space-6);
    backdrop-filter: blur(4px);
  }

  .hero-title {
    font-size: 4rem;
    font-weight: 800;
    color: var(--color-text-inverse);
    letter-spacing: -0.03em;
    margin-bottom: var(--space-2);
    line-height: 1;
  }

  .hero-subtitle {
    font-size: var(--size-xl);
    color: rgba(255, 255, 255, 0.9);
    font-weight: 500;
    margin-bottom: var(--space-6);
  }

  .hero-desc {
    color: rgba(255, 255, 255, 0.75);
    font-size: var(--size-lg);
    line-height: 1.7;
    margin-bottom: var(--space-8);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .card-icon {
    font-size: var(--size-3xl);
    margin-bottom: var(--space-4);
    color: var(--color-primary-light);
  }

  .news-card {
    padding: var(--space-8);
    background: var(--color-bg);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-light);
    transition: all 0.2s ease;
  }

  .news-card:hover {
    box-shadow: var(--shadow-md);
  }

  .news-card .tag {
    margin-bottom: var(--space-4);
  }

  .news-card h3 {
    font-size: var(--size-xl);
    margin-bottom: var(--space-3);
    color: var(--color-primary);
  }

  .news-card h3 a {
    color: inherit;
    text-decoration: none;
  }

  .news-card h3 a:hover {
    color: var(--color-primary-light);
  }

  .news-card p {
    color: var(--color-text-light);
    margin-bottom: var(--space-4);
  }

  .news-card time {
    color: var(--color-text-light);
    font-size: var(--size-sm);
  }

  .news-more {
    text-align: center;
    margin-top: var(--space-10);
  }

  .cta-box {
    background: var(--color-bg-alt);
    border-radius: var(--radius-xl);
    padding: var(--space-12);
    text-align: center;
    border: 1px solid var(--color-border-light);
  }

  .cta-box h2 {
    margin-bottom: var(--space-4);
  }

  .cta-box p {
    color: var(--color-text-light);
    font-size: var(--size-lg);
    max-width: 560px;
    margin: 0 auto var(--space-8);
  }

  @media (min-width: 1024px) {
    .hero {
      min-height: 600px;
    }

    .hero-title {
      font-size: 5rem;
    }
  }
</style>
