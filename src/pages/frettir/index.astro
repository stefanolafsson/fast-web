---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;

const news = (await getCollection('frettir')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

function formatDate(date: Date): string {
  return date.toLocaleDateString('is-IS', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}
---

<Layout title="Fréttir" description="Fréttir og tilkynningar frá FAST.">
  <div class="page-header">
    <div class="container">
      <h1>Fréttir</h1>
      <p>Nýjustu fréttir og tilkynningar frá Félagi akademískra starfsmanna.</p>
    </div>
  </div>

  <div class="page-content">
    <div class="container">
      <div class="news-list">
        {news.map((item) => (
          <a href={`${base}frettir/${item.id}/`} class="news-link">
            <article class="news-item">
              <div class="news-meta">
                <span class="tag">{item.data.tag}</span>
                <time datetime={item.data.date.toISOString()}>{formatDate(item.data.date)}</time>
              </div>
              <h2>{item.data.title}</h2>
              <p>{item.data.excerpt}</p>
              <span class="read-more">Lesa meira &rarr;</span>
            </article>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>

<style>
  .news-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .news-link {
    text-decoration: none;
    color: inherit;
  }

  .news-item {
    padding: var(--space-8);
    background: var(--color-bg);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    transition: all 0.2s ease;
  }

  .news-link:hover .news-item {
    box-shadow: var(--shadow-md);
    border-color: var(--color-border);
  }

  .news-meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .news-meta time {
    color: var(--color-text-light);
    font-size: var(--size-sm);
  }

  .news-item h2 {
    font-size: var(--size-xl);
    margin-bottom: var(--space-3);
  }

  .news-item p {
    color: var(--color-text-light);
    line-height: 1.7;
    max-width: 75ch;
    margin-bottom: var(--space-4);
  }

  .read-more {
    color: var(--color-primary-light);
    font-weight: 600;
    font-size: var(--size-sm);
  }

  .news-link:hover .read-more {
    color: var(--color-primary);
  }
</style>
