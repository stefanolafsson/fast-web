---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-about">
        <div class="footer-logo">FAST</div>
        <p class="footer-desc">
          Félag akademískra starfsmanna við Háskólann í Reykjavík.
          Aðildarfélag BHM — Bandalagsháskólamanna.
        </p>
      </div>

      <div class="footer-links">
        <h4>Flýtileiðir</h4>
        <ul>
          <li><a href={`${base}um-felagid/`}>Um félagið</a></li>
          <li><a href={`${base}stjorn/`}>Stjórn</a></li>
          <li><a href={`${base}kjaramal/`}>Kjaramál</a></li>
          <li><a href={`${base}frettir/`}>Fréttir</a></li>
          <li><a href={`${base}hafa-samband/`}>Hafa samband</a></li>
        </ul>
      </div>

      <div class="footer-links">
        <h4>Tenglar</h4>
        <ul>
          <li><a href="https://www.bhm.is" target="_blank" rel="noopener">BHM — Bandalag háskólamanna</a></li>
          <li><a href="https://www.ru.is" target="_blank" rel="noopener">Háskólinn í Reykjavík</a></li>
        </ul>
      </div>

      <div class="footer-contact">
        <h4>Samband</h4>
        <p>Háskólinn í Reykjavík<br />Menntavegur 1<br />102 Reykjavík</p>
        <p><a href="mailto:fast@ru.is">fast@ru.is</a></p>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} FAST — Félag akademískra starfsmanna við HR. Allur réttur áskilinn.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg-dark);
    color: rgba(255, 255, 255, 0.8);
    padding: var(--space-16) 0 var(--space-8);
    margin-top: auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    margin-bottom: var(--space-12);
  }

  .footer-logo {
    font-size: var(--size-2xl);
    font-weight: 800;
    color: var(--color-text-inverse);
    margin-bottom: var(--space-3);
    letter-spacing: -0.02em;
  }

  .footer-desc {
    color: rgba(255, 255, 255, 0.6);
    font-size: var(--size-sm);
    line-height: 1.7;
    max-width: 280px;
  }

  .footer-links h4,
  .footer-contact h4 {
    color: var(--color-text-inverse);
    font-size: var(--size-base);
    font-weight: 600;
    margin-bottom: var(--space-4);
  }

  .footer-links ul {
    list-style: none;
  }

  .footer-links li {
    margin-bottom: var(--space-2);
  }

  .footer-links a,
  .footer-contact a {
    color: rgba(255, 255, 255, 0.6);
    font-size: var(--size-sm);
    transition: color 0.2s ease;
  }

  .footer-links a:hover,
  .footer-contact a:hover {
    color: var(--color-text-inverse);
  }

  .footer-contact p {
    color: rgba(255, 255, 255, 0.6);
    font-size: var(--size-sm);
    line-height: 1.7;
    margin-bottom: var(--space-2);
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: var(--space-8);
  }

  .footer-bottom p {
    color: rgba(255, 255, 255, 0.4);
    font-size: var(--size-sm);
    text-align: center;
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
    }
  }
</style>
